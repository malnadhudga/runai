#!/usr/bin/env python3
"""Run crew from project root: ./crew or ./crew "goal" (no pip script on PATH needed)."""
import runpy
import sys

# Ensure "crew" package is found (project root = parent of this script's dir when script is in repo root)
import os
_script_dir = os.path.dirname(os.path.abspath(__file__))
_parent = os.path.dirname(_script_dir)
if _parent not in sys.path:
    sys.path.insert(0, _parent)

sys.argv[0] = "crew"
runpy.run_module("crew.cli.main", run_name="__main__")
