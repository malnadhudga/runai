# At least one of: RUNAI_GEMINI_PROXY_URL, GEMINI_API_KEY, or OPENAI_API_KEY.
# Get Gemini (direct mode only): https://aistudio.google.com/apikey
# Get OpenAI: https://platform.openai.com/api-keys

OPENAI_API_KEY=
GEMINI_API_KEY=

# If GEMINI_API_KEY is unset, Gemini calls go here (your server uses its Google key).
# If GEMINI_API_KEY is set, it is used locally; proxy URL is ignored for Gemini.
# Example: https://your-vm.example.com/v1/gemini/chat
RUNAI_GEMINI_PROXY_URL=
# Optional Bearer token your proxy validates (e.g. per-user API key).
RUNAI_GEMINI_PROXY_TOKEN=
# Optional id your proxy logs for usage per customer (also sent as X-Runai-Client-Id).
RUNAI_PROXY_CLIENT_ID=
